        <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="Reseed available_beds from data.sql fixture" enabled="true">
          <stringProp name="dataSource">medhead</stringProp>
          <stringProp name="queryType">Update Statement</stringProp>
          <stringProp name="query">INSERT INTO hospital_specialties (hospital_id, specialty_id, available_beds) VALUES
    (1, 21, 2), (1, 54, 3), (1, 17, 4), (1, 28, 5),
    (2, 21, 0), (2, 17, 3), (2, 28, 2),
    (3, 54, 5), (3, 49, 4), (3, 69, 2), (3, 17, 3), (3, 53, 2),
    (4, 18, 4), (4, 28, 6), (4, 47, 3), (4, 72, 2), (4, 17, 5),
    (5, 21, 3), (5, 42, 4), (5,  2, 2), (5, 17, 6),
    (6,  3, 2), (6, 34, 3), (6, 52, 4), (6, 39, 2), (6, 53, 3),
    (7, 47, 5), (7, 46, 2), (7, 28, 4), (7, 17, 3),
    (8, 36, 3), (8, 73, 2), (8, 17, 4), (8, 72, 5),
    (9, 65, 6), (9, 66, 3), (9, 63, 2), (9, 32, 4),
    (10, 21, 1), (10, 71, 2), (10, 72, 3), (10, 17, 4), (10,  1, 5),
    (11, 78, 4), (11, 17, 5), (11,  1, 3), (11, 77, 2),
    (12, 25, 2), (12, 27, 3), (12, 41, 2), (12, 26, 3), (12, 17, 4)
ON CONFLICT (hospital_id, specialty_id) DO UPDATE
    SET available_beds = EXCLUDED.available_beds,
        version        = 0</stringProp>
          <stringProp name="queryArguments"></stringProp>
          <stringProp name="queryArgumentsTypes"></stringProp>
