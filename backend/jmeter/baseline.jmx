          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Refresh JWT on 401" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">// Refreshes the shared JMeter property &quot;token&quot; when the previous sampler
// returned a 401. Thread-safe via synchronized(props); the first thread through
// re-logs-in, subsequent threads observe the refreshed value.
if (prev != null &amp;&amp; &quot;401&quot;.equals(prev.getResponseCode())) {
    synchronized (props) {
        def protocol = vars.get(&quot;protocol&quot;)
        def host     = vars.get(&quot;host&quot;)
        def port     = vars.get(&quot;port&quot;)
        def user     = vars.get(&quot;user&quot;)
        def password = vars.get(&quot;password&quot;)
        def url  = new URL(protocol + &quot;://&quot; + host + &quot;:&quot; + port + &quot;/api/v1/auth/login&quot;)
        def conn = url.openConnection()
        conn.setRequestMethod(&quot;POST&quot;)
        conn.setDoOutput(true)
        conn.setConnectTimeout(5000)
        conn.setReadTimeout(5000)
        conn.setRequestProperty(&quot;Content-Type&quot;, &quot;application/json&quot;)
        conn.outputStream.withWriter(&quot;UTF-8&quot;) { w -&gt;
            w.write(&apos;{&quot;username&quot;:&quot;&apos; + user + &apos;&quot;,&quot;password&quot;:&quot;&apos; + password + &apos;&quot;}&apos;)
        }
        def status = conn.responseCode
        if (status == 200) {
            def body = conn.inputStream.getText(&quot;UTF-8&quot;)
            def m = body =~ /&quot;token&quot;\s*:\s*&quot;([^&quot;]+)&quot;/
            if (m.find()) {
                props.put(&quot;token&quot;, m.group(1))
                log.info(&quot;JWT refreshed after 401 on &quot; + prev.getSampleLabel())
            }
        } else {
            log.warn(&quot;Token refresh failed with HTTP &quot; + status + &quot; on &quot; + prev.getSampleLabel())
        }
    }
}</stringProp>
          </JSR223PostProcessor>
